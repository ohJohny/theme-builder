{
	"name": "@ohJohny/theme-builder-react",
	"version": "0.1.0",
	"description": "React ThemeProvider, useTheme, and useColorScheme",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ohJohny/theme-builder.git",
		"directory": "packages/react"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"files": ["dist", "scripts/sync-cursor-skills.mjs"],
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/index.js"
		},
		"./skills/*": "./dist/skills/*"
	},
	"scripts": {
		"build": "vite build && tsc -p tsconfig.build.types.json && node scripts/copy-skills.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --passWithNoTests",
		"postinstall": "node scripts/sync-cursor-skills.mjs"
	},
	"dependencies": {
		"@ohJohny/theme-builder-core": "workspace:*"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"devDependencies": {
		"@types/react": "^19.1.8",
		"react": "^19.1.0",
		"typescript": "^6.0.3",
		"vite": "8.0.5"
	}
}
