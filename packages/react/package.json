{
	"name": "@ohJohny/theme-builder-react",
	"private": true,
	"version": "0.1.5",
	"description": "React ThemeProvider, useTheme, and useColorScheme",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ohJohny/theme-builder.git",
		"directory": "packages/react"
	},
	"files": [
		"dist",
		"scripts/sync-cursor-skills.mjs"
	],
	"sideEffects": false,
	"exports": {
		".": {
			"types": "../../dist/react/types/index.d.ts",
			"import": "../../dist/react/index.js"
		},
		"./skills/*": "../../dist/react/skills/*"
	},
	"scripts": {
		"build": "vite build && tsc -p tsconfig.build.types.json && node scripts/copy-skills.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"postinstall": "node scripts/sync-cursor-skills.mjs"
	},
	"dependencies": {
		"@ohJohny/theme-builder-core": "workspace:*"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.1.8",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"typescript": "^6.0.3",
		"vite": "8.0.5",
		"vitest": "^4.1.8"
	}
}
