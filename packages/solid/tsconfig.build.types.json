{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist/types",
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"jsx": "preserve",
		"jsxImportSource": "solid-js"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
