{
	"name": "@ohJohny/theme-builder-solid",
	"private": true,
	"version": "0.1.23",
	"description": "Solid ThemeProvider, useTheme, and useColorScheme",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ohJohny/theme-builder.git",
		"directory": "packages/solid"
	},
	"sideEffects": false,
	"scripts": {
		"build": "vite build && tsc -p tsconfig.build.types.json && node scripts/copy-skills.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"postinstall": "node scripts/sync-cursor-skills.mjs"
	},
	"dependencies": {
		"@ohJohny/theme-builder-core": "workspace:*"
	},
	"peerDependencies": {
		"solid-js": ">=1.8.0"
	},
	"devDependencies": {
		"@solidjs/testing-library": "^0.8.10",
		"solid-js": "1.9.12",
		"typescript": "^6.0.3",
		"vite": "8.0.5",
		"vite-plugin-solid": "2.11.12"
	}
}
