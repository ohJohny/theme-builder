{
	"name": "@ohJohny/theme-builder",
	"version": "0.1.3",
	"description": "Framework-agnostic design tokens with React and Solid providers",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ohJohny/theme-builder.git",
		"directory": "packages/theme-builder"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"files": [
		"dist",
		"scripts/sync-cursor-skills.mjs"
	],
	"sideEffects": false,
	"exports": {
		".": {
			"types": "../../dist/core/types/index.d.ts",
			"import": "../../dist/core/index.js"
		},
		"./core": {
			"types": "../../dist/core/types/index.d.ts",
			"import": "../../dist/core/index.js"
		},
		"./react": {
			"types": "../../dist/react/types/index.d.ts",
			"import": "../../dist/react/index.js"
		},
		"./solid": {
			"types": "../../dist/solid/types/index.d.ts",
			"import": "../../dist/solid/index.js"
		},
		"./skills/*": "../../dist/theme-builder/skills/*"
	},
	"scripts": {
		"build": "node scripts/copy-skills.mjs",
		"postinstall": "node scripts/sync-cursor-skills.mjs"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"solid-js": ">=1.8.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"solid-js": {
			"optional": true
		}
	}
}
