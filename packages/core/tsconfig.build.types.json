{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"types": ["node"],
		"rootDir": "src",
		"outDir": "../../dist/core/types",
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"noEmit": false
	},
	"include": ["src/**/*.ts"],
	"exclude": [
		"src/**/*.test.ts",
		"src/utils/utility-class-map.ts",
		"src/utils/utility-class-hash.ts",
		"src/utils/utility-class-catalog.ts"
	]
}
