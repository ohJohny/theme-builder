{
	"name": "@ohJohny/theme-builder-core",
	"private": true,
	"version": "0.1.4",
	"description": "Framework-agnostic design-token runtime and color-scheme store",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ohJohny/theme-builder.git",
		"directory": "packages/core"
	},
	"files": [
		"dist",
		"scripts/sync-cursor-skills.mjs"
	],
	"sideEffects": false,
	"exports": {
		".": {
			"types": "../../dist/core/types/index.d.ts",
			"import": "../../dist/core/index.js"
		},
		"./skills/*": "../../dist/core/skills/*"
	},
	"scripts": {
		"build": "vite build && tsc -p tsconfig.build.types.json && node scripts/copy-skills.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"generate:utility-class-map": "bun scripts/generate-utility-class-map.ts",
		"postinstall": "node scripts/sync-cursor-skills.mjs"
	},
	"devDependencies": {
		"@types/node": "25.9.1",
		"typescript": "^6.0.3",
		"vite": "8.0.5"
	}
}
