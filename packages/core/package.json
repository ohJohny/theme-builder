{
	"name": "@ohJohny/theme-builder-core",
	"private": true,
	"version": "0.1.22",
	"description": "Framework-agnostic design-token runtime and color-scheme store",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ohJohny/theme-builder.git",
		"directory": "packages/core"
	},
	"sideEffects": [
		"./src/index.ts",
		"./src/store/createColorSchemeStore.ts"
	],
	"scripts": {
		"build": "vite build && vite build --config vite.config.cli.ts && tsc -p tsconfig.build.types.json && node scripts/copy-skills.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"postinstall": "node scripts/sync-cursor-skills.mjs"
	},
	"peerDependencies": {
		"tsx": "^4.19.4"
	},
	"peerDependenciesMeta": {
		"tsx": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "25.9.1",
		"tsx": "^4.19.4",
		"typescript": "^6.0.3",
		"vite": "8.0.5"
	}
}
