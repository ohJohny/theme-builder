{
	"name": "@ohJohny/theme-builder",
	"version": "0.1.21",
	"description": "Framework-agnostic design tokens with React and Solid providers",
	"type": "module",
	"license": "MIT",
	"packageManager": "bun@1.3.9",
	"repository": {
		"type": "git",
		"url": "https://github.com/ohJohny/theme-builder.git"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"files": [
		"dist",
		"scripts/sync-cursor-skills.mjs"
	],
	"sideEffects": false,
	"bin": {
		"theme-builder": "./dist/core/cli/generate.js"
	},
	"dependencies": {
		"tsx": "^4.19.4"
	},
	"exports": {
		".": {
			"types": "./dist/core/types/index.d.ts",
			"import": "./dist/core/index.js"
		},
		"./core": {
			"types": "./dist/core/types/index.d.ts",
			"import": "./dist/core/index.js"
		},
		"./core/build-utils": {
			"types": "./dist/core/types/build-utils.d.ts",
			"import": "./dist/core/build-utils.js"
		},
		"./core/cli": {
			"types": "./dist/core/types/cli/index.d.ts",
			"import": "./dist/core/cli/index.js"
		},
		"./react": {
			"types": "./dist/react/types/index.d.ts",
			"import": "./dist/react/index.js"
		},
		"./solid": {
			"types": "./dist/solid/types/index.d.ts",
			"import": "./dist/solid/index.js"
		},
		"./skills/*": "./dist/theme-builder/skills/*"
	},
	"workspaces": [
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"build": "bun run clean:dist && bun run --filter @ohJohny/theme-builder-core build && bun run --filter '@ohJohny/theme-builder-react' --filter '@ohJohny/theme-builder-solid' build && node scripts/copy-skills.mjs && node scripts/finalize-dist.mjs",
		"clean:dist": "node scripts/clean-dist.mjs",
		"lint": "bun run --filter '@ohJohny/*' lint",
		"test": "bun run --filter '@ohJohny/*' test",
		"typecheck": "bun run --filter @ohJohny/theme-builder-core typecheck && bun run --filter @ohJohny/theme-builder-core build && bun run --filter '@ohJohny/theme-builder-react' --filter '@ohJohny/theme-builder-solid' typecheck",
		"precommit": "bun run typecheck && bun run test",
		"generate:utility-class-map": "echo 'removed: use generateThemeArtifacts from build-utils'",
		"sync:cursor-skills": "node scripts/sync-cursor-skills.mjs",
		"dev:playground": "bun run --filter theme-builder-playground dev",
		"postinstall": "node scripts/sync-cursor-skills.mjs",
		"prepare": "husky"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"solid-js": ">=1.8.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"solid-js": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "25.9.1",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"solid-js": "1.9.12",
		"typescript": "^6.0.3",
		"vite": "8.0.5",
		"vite-plugin-solid": "2.11.12",
		"vitest": "^4.1.7"
	}
}
