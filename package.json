{
	"name": "theme-builder-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.9",
	"workspaces": ["packages/*"],
	"scripts": {
		"build": "bun run --filter '@ohJohny/*' build",
		"lint": "bun run --filter '@ohJohny/*' lint",
		"test": "bun run --filter '@ohJohny/*' test",
		"typecheck": "bun run --filter '@ohJohny/*' typecheck",
		"generate:utility-class-map": "bun run --filter @ohJohny/theme-builder-core generate:utility-class-map"
	},
	"devDependencies": {
		"@types/node": "25.9.1",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"jsdom": "^26.1.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"solid-js": "1.9.12",
		"typescript": "^6.0.3",
		"vite": "8.0.5",
		"vite-plugin-solid": "2.11.12",
		"vitest": "^4.1.7"
	}
}
