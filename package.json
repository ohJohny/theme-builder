{
	"name": "theme-builder-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"build": "bun run --filter '@ohJohny/*' build",
		"lint": "bun run --filter '@ohJohny/*' lint",
		"test": "bun run --filter '@ohJohny/*' test",
		"typecheck": "bun run --filter '@ohJohny/*' typecheck",
		"precommit": "bun run typecheck && bun run test",
		"generate:utility-class-map": "bun run --filter @ohJohny/theme-builder-core generate:utility-class-map",
		"sync:cursor-skills": "node scripts/sync-cursor-skills.mjs",
		"dev:playground": "bun run --filter theme-builder-playground dev",
		"postinstall": "node scripts/sync-cursor-skills.mjs",
		"prepare": "husky"
	},
	"devDependencies": {
		"@types/node": "25.9.1",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"solid-js": "1.9.12",
		"typescript": "^6.0.3",
		"vite": "8.0.5",
		"vite-plugin-solid": "2.11.12",
		"vitest": "^4.1.7"
	}
}
